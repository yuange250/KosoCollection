{
  "name": "koso-world",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node server/index.mjs\"",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "ingest": "node scripts/ingest.mjs",
    "gen:bulk": "node scripts/gen-bulk-games.mjs",
    "fetch:bgm:cn": "node scripts/fetch-bgm-games-cn.mjs",
    "enrich:images": "node scripts/fetch-images-rawg.mjs",
    "cache:images": "node scripts/cache-node-images.mjs",
    "cache:worldscene-images": "node scripts/cache-worldscene-images.mjs",
    "cache:worldscene-poi": "node scripts/cache-worldscene-poi-catalog.mjs",
    "rebuild:worldscene-poi": "node scripts/rebuild-worldscene-poi-catalog.mjs",
    "report:worldscene-poi": "node scripts/report-worldscene-poi-status.mjs",
    "clean:worldscene-poi": "node scripts/clean-worldscene-poi-orphans.mjs",
    "pipeline:worldscene-poi": "node scripts/run-worldscene-poi-pipeline.mjs",
    "cache:worldscene-unsplash": "node scripts/cache-worldscene-unsplash.mjs",
    "audit:worldscene-poi": "node scripts/audit-worldscene-poi-catalog.mjs",
    "prune:worldscene-dupes": "node scripts/prune-worldscene-duplicate-images.mjs",
    "candidates:worldscene": "node scripts/worldscene-candidates.mjs write",
    "candidates:worldscene:stats": "node scripts/worldscene-candidates.mjs stats",
    "candidates:worldscene:wikidata": "node scripts/worldscene-candidates.mjs wikidata",
    "candidates:worldscene:bulk": "node scripts/fetch-worldscene-candidates-bulk.mjs",
    "backfill:candidate-coords": "node scripts/backfill-candidate-poi-coords.mjs",
    "backfill:candidate-descriptions": "node scripts/backfill-candidate-poi-descriptions.mjs",
    "geocode:candidate-nominatim": "node scripts/geocode-candidate-poi-nominatim.mjs",
    "candidates:stats": "node scripts/candidate-poi-stats.mjs",
    "pipeline:candidates": "node scripts/run-candidate-poi-pipeline.mjs",
    "candidates:apply-seed-fixes": "node scripts/apply-candidate-wikidata-seed-fixes.mjs",
    "candidates:apply-coord-overrides": "node scripts/apply-candidate-coord-overrides.mjs",
    "cache:candidate-poi-images": "node scripts/cache-candidate-poi-images.mjs",
    "cache:candidate-poi-images:parallel": "node scripts/run-candidate-poi-images-parallel.mjs",
    "merge:candidate-poi-manifests": "node scripts/merge-candidate-poi-manifests.mjs",
    "report:candidate-poi-images": "node scripts/report-candidate-poi-images.mjs",
    "candidates:fetch-images": "node scripts/fetch-candidate-poi-images.mjs",
    "geocode:candidate-nominatim:wikidata": "node scripts/geocode-candidate-poi-nominatim.mjs --wikidata-fallback",
    "pack:ecs": "bash deploy/pack-ecs-bundle.sh",
    "gen:cn-bulk": "node scripts/gen-cn-games-bulk.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@supabase/supabase-js": "^2.49.1",
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "three": "^0.183.2",
    "three-globe": "^2.45.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^3.2.29",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
