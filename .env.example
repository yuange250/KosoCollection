# 前端（可选）若 API 不在同域；生产与 Node 同机同域时留空，使用相对路径 /api/*
# VITE_API_BASE=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# 后端服务
# PORT=3001
# HOST=127.0.0.1

# 邮件通知（163 邮箱 SMTP）
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your_email@163.com
# SMTP_PASS=你的163邮箱授权码（非登录密码）
# NOTIFY_EMAIL=chen_the_best@163.com

# 服务端 / Vercel（任选，用于 /api 与 ingest）
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# AI 抓取脚本 scripts/ingest.mjs
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# PEXELS_API_KEY=

# 图片补全策略（仅国内源：百度百科 + Bangumi）
# BAIDU_SLEEP_MS=180
# BGM_SLEEP_MS=180

# Bangumi 国内批量抓取 scripts/fetch-bgm-games-cn.mjs
# BGM_START_PAGE=1
# BGM_MAX_PAGES=120
# BGM_SORT=rank
# BGM_CHUNK_SIZE=4000
# BGM_SLEEP_MS=180
